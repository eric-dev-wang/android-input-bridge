<idea-plugin>
    <id>com.ericdevwang.inputbridge.plugin</id>
    <name>Input Bridge</name>
    <vendor>Input Bridge</vendor>

    <description><![CDATA[
        Displays temporary text from Input Bridge in an IntelliJ Platform tool window.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.android</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Input Bridge" displayType="BALLOON" />
        <projectService serviceImplementation="com.ericdevwang.inputbridge.plugin.service.InputBridgeProjectService"/>
        <toolWindow
                id="Input Bridge"
                anchor="right"
                icon="/icons/inputBridge.svg"
                factoryClass="com.ericdevwang.inputbridge.plugin.toolwindow.InputBridgeToolWindowFactory"/>
    </extensions>
</idea-plugin>
